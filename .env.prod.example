# GoPay 生产环境 env 示例
# 适用于 podman compose / docker compose
# 只保留单行变量；PEM/证书请放文件中，通过 *_PATH 引用

SERVER_PORT=8080
SERVER_ENV=production
PUBLIC_BASE_URL=https://pay.example.com
LOG_LEVEL=info

DB_HOST=postgres
DB_PORT=5432
DB_USER=gopay
DB_PASSWORD=replace-with-strong-password
DB_NAME=gopay
DB_SSLMODE=require

MASTER_KEY=replace-with-32-byte-secret
ADMIN_API_KEY=replace-with-strong-admin-key
ADMIN_IP_WHITELIST=10.0.0.0/8,127.0.0.1,::1

RUN_MIGRATIONS=false
# 生产环境请单独执行迁移，服务实例不要在启动时自动迁移
MIGRATIONS_PATH=file://migrations

ALIPAY_APP_ID=your_production_alipay_app_id
ALIPAY_APP_PRIVATE_KEY_PATH=certs/alipay/app_private_key.pem
ALIPAY_PUBLIC_KEY_PATH=certs/alipay/alipay_public_key.pem
ALIPAY_GATEWAY_URL=https://openapi.alipay.com/gateway.do

WECHAT_MCH_ID=your_production_mch_id
WECHAT_APP_ID=your_production_app_id
WECHAT_API_V3_KEY=replace-with-32-char-api-v3-key
WECHAT_SERIAL_NO=your_wechat_cert_serial_no
WECHAT_PRIVATE_KEY_PATH=certs/wechat/apiclient_key.pem
WECHAT_CERT_PATH=certs/wechat/apiclient_cert.pem
WECHAT_PLATFORM_CERT_PATH=certs/wechat/platform_cert.pem
WECHAT_API_URL=https://api.mch.weixin.qq.com
WECHAT_NOTIFY_URL=https://pay.example.com/api/v1/webhook/wechat
