# ==================== GoPay 统一支付网关配置文件 ====================
#
# 本文件包含 GoPay 支付网关的所有配置项
# 复制此文件为 .env 并根据实际情况修改配置值
#
# 快速开始:
#   1. cp .env.example .env
#   2. 修改数据库配置
#   3. 生成强密钥 (openssl rand -base64 32)
#   4. 配置支付渠道（支付宝/微信支付）
#   5. 运行数据库迁移
#   6. 启动服务
#
# 详细配置说明请查看: docs/配置指南.md
# =====================================================================

# ==================== 服务配置 ====================

# HTTP 服务监听端口
# 默认: 8080
# 生产环境建议使用反向代理（Nginx/Caddy）并配置 HTTPS
SERVER_PORT=8080

# GoPay 对外访问基础地址
# 用于生成支付渠道 Webhook/回调地址
# 开发环境默认: http://localhost:8080
# 生产环境请填写公网可访问域名，例如: https://pay.example.com
PUBLIC_BASE_URL=http://localhost:8080

# 日志级别
# 可选值: debug, info, warn, error
# 开发环境建议使用 debug，生产环境建议使用 info 或 warn
LOG_LEVEL=debug

# 日志文件路径（可选）
# 如果不设置，日志将只输出到控制台
# 建议生产环境配置日志文件便于问题排查
LOG_FILE=logs/gopay.log

# ==================== 数据库配置 ====================

# PostgreSQL 数据库地址
# 本地开发: localhost
# Docker: postgres (服务名)
# 生产环境: 实际数据库地址
DB_HOST=localhost

# PostgreSQL 数据库端口
# 默认: 5432
DB_PORT=5432

# 数据库用户名
DB_USER=gopay

# 数据库密码
# ⚠️ 生产环境必须使用强密码！
# 建议: 至少 16 位，包含大小写字母、数字和特殊字符
DB_PASSWORD=gopay_dev_password

# 数据库名称
DB_NAME=gopay

# SSL 模式
# 可选值: disable, require, verify-ca, verify-full
# 开发环境: disable
# 生产环境: require 或更高级别
DB_SSLMODE=disable

# ==================== 安全配置 ====================

# 主密钥（Master Key）
# 用途: 加密存储商户的支付渠道密钥（支付宝私钥、微信 API 密钥等）
# ⚠️ 极其重要！泄露将导致所有商户密钥被解密
# 生成方法: openssl rand -base64 32
# 轮换周期: 建议每 180 天轮换一次
# 轮换工具: go run cmd/rotate-keys/main.go --type=master-key
MASTER_KEY=your-master-key-change-in-production

# 管理后台 API Key
# 用途: 保护管理后台接口（/admin/*）
# 生成方法: openssl rand -base64 32
# 轮换周期: 建议每 90 天轮换一次
# 使用方法: curl -H "X-API-Key: your-key" http://localhost:8080/admin/orders
ADMIN_API_KEY=default-insecure-key-change-me

# 管理后台 IP 白名单（可选）
# 格式: 逗号分隔的 IP 地址或 CIDR 网段
# 示例: 127.0.0.1,192.168.1.100,10.0.0.0/8
# 留空表示不限制 IP（不推荐生产环境）
# IPv6 支持: ::1 表示本地回环
ADMIN_IP_WHITELIST=127.0.0.1,::1

# ==================== Docker 配置 ====================

# 是否在容器启动时自动运行数据库迁移
# true: 自动运行迁移（适合开发环境）
# false: 手动运行迁移（推荐生产环境，便于控制）
# 手动运行: docker-compose exec gopay /app/migrate up
RUN_MIGRATIONS=false

# 数据库迁移文件路径
# Docker 内部使用，一般不需要修改
MIGRATIONS_PATH=file://migrations

# ==================== 支付宝配置 ====================
#
# 配置前准备:
#   1. 注册支付宝开放平台账号: https://open.alipay.com/
#   2. 创建应用并通过审核
#   3. 生成 RSA2 密钥对
#   4. 上传应用公钥到支付宝平台
#   5. 获取支付宝公钥
#
# 详细步骤请查看: docs/配置指南.md#支付宝配置
# =====================================================================

# 支付宝应用 ID（必填）
# 获取位置: 开放平台 > 控制台 > 应用详情 > APPID
# 格式: 16 位数字
# 示例: 2021001234567890
ALIPAY_APP_ID=your_alipay_app_id

# 支付宝应用私钥（必填）
# 用途: 对请求参数进行签名
# 格式: RSA2 (2048位) PEM 格式，包含 BEGIN/END 标记
# 生成方法:
#   openssl genrsa -out alipay_private_key.pem 2048
#   openssl rsa -in alipay_private_key.pem -pubout -out alipay_public_key.pem
# ⚠️ 注意:
#   - 必须包含完整的 PEM 格式（包括 -----BEGIN RSA PRIVATE KEY----- 等标记）
#   - 可以使用多行格式，保持原始换行符
#   - 建议每 90 天轮换一次
ALIPAY_APP_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----
MIIEpAIBAAKCAQEA...
-----END RSA PRIVATE KEY-----

# 支付宝公钥（必填）
# 用途: 验证支付宝返回数据的签名
# 获取位置: 开放平台 > 应用详情 > 开发信息 > 接口加签方式 > 查看支付宝公钥
# ⚠️ 重要: 这是「支付宝公钥」，不是「应用公钥」！
# 格式: RSA2 PEM 格式，包含 BEGIN/END 标记
ALIPAY_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----
MIIBIjANBgkqhkiG9w0BAQEFAAOCAQ8AMIIBCgKCAQEA...
-----END PUBLIC KEY-----

# 支付宝网关地址
# 正式环境: https://openapi.alipay.com/gateway.do
# 沙箱环境: https://openapi.alipaydev.com/gateway.do
# ⚠️ 生产环境必须使用正式环境地址
ALIPAY_GATEWAY_URL=https://openapi.alipaydev.com/gateway.do

# 签名类型
# 推荐: RSA2 (更安全)
# 可选: RSA (不推荐，安全性较低)
ALIPAY_SIGN_TYPE=RSA2

# 字符集
# 固定值: utf-8
ALIPAY_CHARSET=utf-8

# 数据格式
# 固定值: json
ALIPAY_FORMAT=json

# ==================== 微信支付配置 ====================
#
# 配置前准备:
#   1. 申请微信支付商户号: https://pay.weixin.qq.com/
#   2. 创建应用（公众号/小程序/APP）
#   3. 在商户平台设置 API v3 密钥
#   4. 申请并下载 API 证书
#   5. 查看证书序列号
#
# 详细步骤请查看: docs/配置指南.md#微信支付配置
# =====================================================================

# 微信支付商户号（必填）
# 获取位置: 商户平台 > 账户中心 > 商户信息 > 商户号
# 格式: 10 位数字
# 示例: 1234567890
WECHAT_MCH_ID=your_mch_id

# 微信应用 ID（必填）
# 获取位置:
#   - 公众号: 公众平台 > 开发 > 基本配置 > AppID
#   - 小程序: 小程序后台 > 开发 > 开发设置 > AppID
#   - APP: 开放平台 > 管理中心 > 应用详情 > AppID
# 格式: wx 开头的字符串
# 示例: wx1234567890abcdef
WECHAT_APP_ID=your_app_id

# 微信支付 API v3 密钥（必填）
# 用途: 加密/解密敏感信息，验证回调签名
# 设置位置: 商户平台 > 账户中心 > API安全 > 设置APIv3密钥
# 格式: 32 位字符串（数字+字母）
# 生成方法: openssl rand -hex 16
# ⚠️ 注意:
#   - 必须在商户平台设置后才能使用
#   - 建议每 90 天轮换一次
#   - 设置后无法查看，请妥善保管
WECHAT_API_V3_KEY=your_32_character_api_v3_key_here

# 商户证书序列号（必填）
# 用途: 标识商户证书，用于签名验证
# 查看方法: openssl x509 -in apiclient_cert.pem -noout -serial
# 格式: 40 位十六进制字符串（大写）
# 示例: 1234567890ABCDEF1234567890ABCDEF12345678
WECHAT_SERIAL_NO=your_certificate_serial_number

# 商户私钥文件路径（必填）
# 用途: 对请求进行签名
# 获取方法: 商户平台 > 账户中心 > API安全 > 申请API证书
# 文件名: apiclient_key.pem
# ⚠️ 注意:
#   - 路径相对于项目根目录
#   - 文件权限建议设置为 600 (仅所有者可读写)
#   - 不要提交到 Git 仓库
WECHAT_PRIVATE_KEY_PATH=certs/wechat/apiclient_key.pem

# 商户证书文件路径（必填）
# 用途: 标识商户身份
# 获取方法: 与私钥一起下载
# 文件名: apiclient_cert.pem
WECHAT_CERT_PATH=certs/wechat/apiclient_cert.pem

# 微信支付平台证书路径（可选）
# 用途: 验证微信支付返回数据的签名
# 说明: 如果不配置，SDK 会自动下载并缓存
# 建议: 生产环境可以预先下载并配置，提高启动速度
WECHAT_PLATFORM_CERT_PATH=certs/wechat/platform_cert.pem

# 微信支付 API 地址
# 正式环境: https://api.mch.weixin.qq.com
# 一般不需要修改
WECHAT_API_URL=https://api.mch.weixin.qq.com

# Webhook 回调通知地址（生产环境必填）
# 用途: 接收微信支付的异步通知（支付成功、退款成功等）
# 格式: https://your-domain.com/api/v1/webhook/wechat
# ⚠️ 注意:
#   - 必须是公网可访问的 HTTPS 地址
#   - 开发环境可以使用 ngrok 等工具暴露本地服务
#   - 路径固定为 /api/v1/webhook/wechat
WECHAT_NOTIFY_URL=https://your-domain.com/api/v1/webhook/wechat

# ==================== 其他服务配置 ====================

# Adminer 数据库管理工具端口
# 访问地址: http://localhost:8081
# 仅开发环境使用，生产环境建议关闭
ADMINER_PORT=8081

# ==================== 监控配置（可选）====================

# Prometheus 监控端口
# 访问地址: http://localhost:9090
PROMETHEUS_PORT=9090

# Grafana 可视化端口
# 访问地址: http://localhost:3000
GRAFANA_PORT=3000

# Grafana 管理员用户名
GRAFANA_USER=admin

# Grafana 管理员密码
# ⚠️ 生产环境必须修改默认密码
GRAFANA_PASSWORD=admin

# ==================== 应用版本 ====================

# 应用版本号
# 构建时会自动注入到二进制文件
# 开发环境: dev
# 生产环境: 使用 Git tag 或语义化版本号（如 v1.0.0）
VERSION=dev

# ==================== 生产环境额外配置 ====================
# 以下配置仅在生产环境需要启用
# 开发环境可以注释掉

# ---------- HTTPS 配置 ----------
# 生产环境强烈建议启用 HTTPS

# 是否启用 HTTPS
# true: 启用 HTTPS（需要配置证书）
# false: 使用 HTTP（仅开发环境）
# ENABLE_HTTPS=true

# TLS 证书文件路径
# 获取方式:
#   - Let's Encrypt 免费证书: certbot
#   - 云服务商提供的证书
#   - 购买的商业证书
# TLS_CERT_PATH=/path/to/cert.pem

# TLS 私钥文件路径
# TLS_KEY_PATH=/path/to/key.pem

# ---------- 限流配置 ----------
# 防止 API 被滥用

# 是否启用限流
# RATE_LIMIT_ENABLED=true

# 每个 IP 允许的请求数
# RATE_LIMIT_REQUESTS=100

# 时间窗口
# 格式: 数字+单位 (s=秒, m=分钟, h=小时)
# 示例: 1m 表示 1 分钟内最多 100 个请求
# RATE_LIMIT_DURATION=1m

# ---------- 跨域配置 ----------
# 如果前端和后端部署在不同域名

# 允许的来源（逗号分隔）
# 示例: https://your-frontend.com,https://admin.your-domain.com
# CORS_ALLOWED_ORIGINS=https://your-frontend.com

# 允许的 HTTP 方法
# CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE

# 允许的 HTTP Header
# CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-API-Key

# ---------- 错误追踪配置 ----------
# 使用 Sentry 追踪生产环境错误

# Sentry DSN
# 获取位置: Sentry 项目设置 > Client Keys (DSN)
# SENTRY_DSN=https://xxx@sentry.io/xxx

# 环境标识
# 用于区分不同环境的错误
# SENTRY_ENVIRONMENT=production

# ---------- 对账任务配置 ----------
# T+1 自动对账

# 是否启用自动对账
# true: 启用定时对账任务
# false: 手动执行对账
# RECONCILIATION_ENABLED=true

# 对账任务执行时间（Cron 表达式）
# 格式: 分 时 日 月 周
# 示例: 0 2 * * * 表示每天凌晨 2 点执行
# 建议: 凌晨执行，避免影响白天业务
# RECONCILIATION_SCHEDULE=0 2 * * *

# ==================== 配置文件结束 ====================
#
# 下一步:
#   1. 复制此文件: cp .env.example .env
#   2. 修改 .env 中的配置值
#   3. 生成强密钥: openssl rand -base64 32
#   4. 配置支付渠道（参考 docs/配置指南.md）
#   5. 运行数据库迁移: go run cmd/migrate/main.go up
#   6. 启动服务: go run cmd/gopay/main.go
#   7. 访问健康检查: curl http://localhost:8080/health
#
# 遇到问题?
#   - 查看配置指南: docs/配置指南.md
#   - 查看部署检查清单: DEPLOYMENT_CHECKLIST.md
#   - 提交 Issue: https://github.com/yourusername/gopay/issues
#
# =====================================================================
