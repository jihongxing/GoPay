# 服务配置
SERVER_PORT=8080
LOG_LEVEL=debug

# 数据库配置
DB_HOST=localhost
DB_PORT=5432
DB_USER=gopay
DB_PASSWORD=gopay_dev_password
DB_NAME=gopay
DB_SSLMODE=disable

# 主密钥（用于加密商户密钥）
# 生产环境请使用强密钥！
MASTER_KEY=your-master-key-change-in-production

# Adminer 端口
ADMINER_PORT=8081

# 监控配置（可选）
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# 应用版本
VERSION=dev
