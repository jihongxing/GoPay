# GoPay 服务地址
GOPAY_URL=http://localhost:8080

# 应用ID（必填）
APP_ID=your_app_id

# 支付渠道
# 可选值: wechat_native, wechat_jsapi, wechat_h5, wechat_app
#        alipay_qr, alipay_wap, alipay_app, alipay_face
CHANNEL=wechat_native

# 回调地址
NOTIFY_URL=http://localhost:8081/callback

# 回调服务器端口
CALLBACK_PORT=8081
